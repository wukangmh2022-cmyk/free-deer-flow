{
  "name": "deerflowwithdeepseek-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for deerflowwithdeepseek",
  "main": "main.cjs",
  "scripts": {
    "dev": "pnpm run dev:static",
    "dev:static": "pnpm run prepare:frontend && DEER_FLOW_USE_STATIC_FRONTEND=1 electron .",
    "dist:mac": "pnpm run prepare:frontend && pnpm run prepare:mac-python && electron-builder --mac dir",
    "dist:dmg": "pnpm run prepare:frontend && pnpm run prepare:mac-python && electron-builder --mac dmg",
    "prepare:frontend": "node ./scripts/build-static-frontend.mjs",
    "prepare:mac-python": "bash ../../scripts/prepare-mac-python-runtime.sh",
    "prepare:win-python": "powershell -ExecutionPolicy Bypass -File ../../scripts/prepare-windows-python-runtime.ps1",
    "dist:win:dir": "pnpm run prepare:frontend && electron-builder --win dir --x64 --publish never",
    "dist:win:thin": "pnpm run prepare:frontend && electron-builder --win dir --x64 --publish never",
    "dist:win": "pnpm run prepare:frontend && electron-builder --win dir --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.deerflowwithdeepseek.desktop",
    "productName": "DeerFlowWithDeepSeek",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "static-server.cjs",
      "scripts/build-static-frontend.mjs"
    ],
    "extraResources": [
      {
        "from": "../../backend",
        "to": "runtime/backend",
        "filter": [
          "**/*",
          "!**/.venv",
          "!**/.venv/**",
          "!**/.deer-flow",
          "!**/.deer-flow/**",
          "!**/.langgraph_api",
          "!**/.langgraph_api/**",
          "!**/__pycache__",
          "!**/__pycache__/**",
          "!**/.pytest_cache",
          "!**/.pytest_cache/**",
          "!**/tests",
          "!**/tests/**",
          "!**/docs",
          "!**/docs/**",
          "!**/.vscode",
          "!**/.vscode/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!debug*.py",
          "!README.md",
          "!CLAUDE.md",
          "!AGENTS.md",
          "!CONTRIBUTING.md"
        ]
      },
      {
        "from": "runtime/frontend-static",
        "to": "runtime/frontend-static",
        "filter": [
          "**/*",
          "!demo",
          "!demo/**"
        ]
      },
      {
        "from": "../../skills",
        "to": "runtime/skills"
      },
      {
        "from": "runtime/python",
        "to": "runtime/python"
      },
      {
        "from": "../../config.yaml",
        "to": "runtime/config.yaml"
      },
      {
        "from": "../../config.example.yaml",
        "to": "runtime/config.example.yaml"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "packageManager": "pnpm@10.26.2"
}
